# =============================================================================
# Railway → signature-keyra service → Variables
# Paste the block below (replace CHANGE_ME secrets before deploy).
# Do NOT set SIGNATURERS_DEV_* in production.
# =============================================================================

NODE_ENV=production

# Public URLs (must match your custom domain)
NEXT_PUBLIC_SIGNATURERS_URL=https://signaturers.keyra.ie
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.keyra.ie
NEXT_PUBLIC_KEYRA_MARKETING_ORIGIN=https://keyra.ie
NEXT_PUBLIC_GET_STARTED_URL=https://get-started.keyra.ie

# Secrets — generate two random 48+ char strings (openssl rand -base64 48)
KEYRA_SESSION_SECRET=CHANGE_ME_KEYRA_SESSION_SECRET
SIGNATURERS_PREVIEW_SECRET=CHANGE_ME_SIGNATURERS_PREVIEW_SECRET

# Identity core (UID → EID / world mappings). Leave empty only if using mock (not recommended in prod).
KEYRA_IDENTITY_CORE_URL=
KEYRA_IDENTITY_CORE_API_KEY=

# Document / signature index API. Leave empty only if SIGNATURERS_USE_MOCK_DATA=true.
SIGNATURERS_INDEX_URL=
SIGNATURERS_INDEX_API_KEY=
SIGNATURERS_USE_MOCK_DATA=false

# S3 vault for imported documents (required for Import feature)
S3_BUCKET=CHANGE_ME_BUCKET_NAME
S3_REGION=us-east-1
S3_SIGNATURERS_PREFIX=keyra-signaturers-vault
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY

# Optional
# NEXT_PUBLIC_SIMSECURE_URL=https://app.keyra.ie
# NEXT_PUBLIC_DEVELOPER_URL=https://developer.keyra.ie
# KEYRA_LAUNCHER_APPS_URL=https://keyra.ie/api/deployments/apps/launcher
