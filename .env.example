# signaturers.keyra.ie
NEXT_PUBLIC_SIGNATURERS_URL=https://signaturers.keyra.ie
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.keyra.ie
NEXT_PUBLIC_KEYRA_MARKETING_ORIGIN=https://keyra.ie
NEXT_PUBLIC_GET_STARTED_URL=https://get-started.keyra.ie

# Session signing (required in production)
KEYRA_SESSION_SECRET=

# Identity core — resolves UID + EID mappings from global Keyra identity
KEYRA_IDENTITY_CORE_URL=
KEYRA_IDENTITY_CORE_API_KEY=

# Document/signature index upstream (optional; mock data used when unset)
SIGNATURERS_INDEX_URL=
SIGNATURERS_INDEX_API_KEY=

# Development: seed demo records when no upstream index
SIGNATURERS_USE_MOCK_DATA=true

# Local full UI without auth backend (never enable in production)
SIGNATURERS_DEV_BYPASS_AUTH=true
SIGNATURERS_DEV_UID=keyra-uid-dev-signaturers-local
SIGNATURERS_DEV_DISPLAY_NAME=Dev Vault User

# S3 vault storage
S3_BUCKET=
S3_REGION=us-east-1
S3_SIGNATURERS_PREFIX=keyra-signaturers-vault
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Preview token signing
SIGNATURERS_PREVIEW_SECRET=
